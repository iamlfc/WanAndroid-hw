{
  "app": {
    "products": [
      {
        "name": "default",
        "targetSdkVersion": "6.0.1(21)",
        "compatibleSdkVersion": "6.0.1(21)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug",
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "phone",
      "srcPath": "./product/phone",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "common",
      "srcPath": "./base/common",
    },
    {
      "name": "home",
      "srcPath": "./feature/home",
    },
    {
      "name": "user",
      "srcPath": "./feature/user",
    },
    {
      "name": "course",
      "srcPath": "./feature/course",
    },
    {
      "name": "square",
      "srcPath": "./feature/square",
    }
  ]
}